# Omarapay – POS integration env
# Copy to .env. For end-to-end demo these values work with backend on port 4000.

# Show "Accept Payments (POS)" in user dashboard (false = hide)
VITE_SHOW_POS=true

# Crypto POS backend URL (origin only, no /api path)
VITE_POS_API_BASE_URL=http://localhost:4000

# Default POS company id for UI hints (matches seeded company, usually company_1)
VITE_POS_DEFAULT_COMPANY_ID=company_1
# Production (Vercel SPA + ngrok/VPS API example — set the same value in Vercel env before build):
VITE_POS_API_BASE_URL=https://your-api.ngrok-free.dev

# Optional dedicated auth API base URL (defaults to VITE_POS_API_BASE_URL)
# Production / tunnel example (set in Vercel env before build):
# VITE_AUTH_API_BASE_URL=https://your-tunnel.ngrok-free.dev

# Admin API key (must match backend ADMIN_API_KEY for POS Coins/Payments)
VITE_POS_ADMIN_API_KEY=demo-admin-key

# Google Maps API key (Business Locator, location picker). Create/restrict in Google Cloud Console.
# VITE_GOOGLE_MAPS_API_KEY=your_key_here

# Google OAuth Client ID (for "Sign in with Google" on user login). Create in Google Cloud Console > APIs & Services > Credentials.
VITE_GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com

# WalletConnect / Reown Cloud project ID (RainbowKit). Required for WalletConnect QR on production.
# Create at https://cloud.reown.com — add your frontend origin (e.g. https://omara-frontend.vercel.app) to the project allowlist.
# VITE_WALLETCONNECT_PROJECT_ID=your_project_id

# Optional: JSON-RPC URLs for Wagmi (browser CORS). Defaults avoid viem fallbacks like eth.merkle.io that block Vercel origins.
# Use Alchemy/Infura/QuickNode HTTPS endpoints in production if you hit rate limits.
VITE_RPC_MAINNET=https://cloudflare-eth.com
VITE_RPC_POLYGON=https://polygon-rpc.com
VITE_RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
VITE_RPC_OPTIMISM=https://mainnet.optimism.io
VITE_RPC_BASE=https://mainnet.base.org
VITE_RPC_AVALANCHE=https://api.avax.network/ext/bc/C/rpc
VITE_RPC_AVALANCHE_FUJI=https://api.avax-test.network/ext/bc/C/rpc

# Super Admin wallet whitelist (comma-separated). Overrides built-in defaults when set. Example:
# VITE_ADMIN_WALLETS=0xabc...,0xdef...

# Optional: enable merged client POS integration modules (off by default).
# VITE_POS_CLIENT_MODULES=true
