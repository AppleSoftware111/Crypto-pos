############################################
# Mobile App Environment Configuration
# Copy to .env. Expo only exposes EXPO_PUBLIC_* to the app.
############################################

# Backend API origin (same value as Vercel VITE_POS_API_BASE_URL for the Omarapay web app).
# EAS: set in eas.json env per profile or `eas secret:create` / project Environment Variables.
#
# - Staging/production: https://your-api.example.com or https://xxxx.ngrok-free.dev
# - Android emulator (local dev): http://10.0.2.2:4000
# - iOS Simulator (local dev): http://127.0.0.1:4000
# - Physical device (local): LAN IP or tunnel; 10.0.2.2 does NOT work on real phones
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000
# Examples:
# EXPO_PUBLIC_API_BASE_URL=https://xxxx.ngrok-free.dev
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:4000

EXPO_PUBLIC_APP_ENV=development

# Optional Omarapay integration (leave empty if unused)
OMARAPAY_API_KEY=
OMARAPAY_API_SECRET=
OMARAPAY_TOKEN=

# POS / card override (demo and testing)
EXPO_PUBLIC_ALLOW_MANUAL_CARD_OVERRIDE=true
EXPO_PUBLIC_CARD_OVERRIDE_PIN=1234
EXPO_PUBLIC_ALLOW_POS_SDK_SIMULATION=false

