# ==========================================
# Backend Environment Configuration
# Copy to .env and adjust values.
# ==========================================

# Runtime
NODE_ENV=development
PORT=4000
SESSION_SECRET=replace_with_strong_random_secret_32_chars_min

# Default company/cashier (used by initDefaultCompany)
# In production, set these to avoid insecure defaults.
COMPANY_PASSWORD=company123
CASHIER_PASSWORD=cashier123
COMPANY_NAME=Default Company
CASHIER_NAME=Cashier 1

# Crypto Wallet / Explorer (leave empty if not used)
BTC_WALLET_ADDRESS=
AVALANCHE_WALLET_ADDRESS=
SNOWTRACE_API_KEY=

# Card Processor (e.g. Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Omarapay integration (comma-separated origins for CORS)
# For local demo: CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Leave empty to allow all origins in development.
CORS_ORIGINS=

# Admin API key (optional). Same value as Omarapay VITE_POS_ADMIN_API_KEY for POS Coins/Payments in admin.
# For demo: ADMIN_API_KEY=demo-admin-key
ADMIN_API_KEY=demo-admin-key

# User auth (JWT + Google OAuth)
# IMPORTANT: replace secrets with long random values in production.
JWT_ACCESS_SECRET=replace_with_strong_random_access_secret
JWT_REFRESH_SECRET=replace_with_strong_random_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Auth rate limits (per IP, 15 min window). Credential routes only: POST /register, /login, /google.
AUTH_RATE_LIMIT_MAX=200
# Refresh + logout (SPA can call these often). Default 500 / 15 min.
# AUTH_SESSION_RATE_LIMIT_MAX=500
# Google OAuth Web Client ID used for backend id_token verification
GOOGLE_OAUTH_CLIENT_ID=

# Rate limiting (optional; default 200 per 15 min per IP)
# RATE_LIMIT_MAX=200

# Monitoring (optional)
SENTRY_DSN=

